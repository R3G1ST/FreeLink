# FreeLink Environment Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=your_telegram_admin_id_here

# Hysteria 2 Configuration
HYSTERIA_USER_PASSWORD=generate_strong_password_here
HYSTERIA_OBFS_PASSWORD=generate_strong_password_here

# PostgreSQL Database
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=freelink_db
PG_USER=freelink
PG_PASS=your_postgres_password_here

# API Security
API_TOKEN=generate_random_token_here

# Server Configuration
SERVER_IP=your_server_ip_here
DOMAIN=your_domain_here

# CORS (comma-separated origins)
ALLOWED_ORIGINS=https://your_domain_here

# SSH Encryption Key (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SSH_ENCRYPTION_KEY=generate_key_here

# Node API Key (for node registration)
NODE_API_KEY=generate_random_key_here
