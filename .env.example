# FreeLink Environment Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=853320816

# Hysteria 2 Configuration
HYSTERIA_USER_PASSWORD=your_hysteria_user_password_here
HYSTERIA_OBFS_PASSWORD=your_hysteria_obfs_password_here

# PostgreSQL Database
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=freelink_db
PG_USER=freelink
PG_PASS=your_postgres_password_here

# API Security
API_TOKEN=your_api_token_here

# Server Configuration
SERVER_IP=45.43.137.87
DOMAIN=link.qmbox.ru

# CORS (comma-separated origins)
ALLOWED_ORIGINS=https://link.qmbox.ru

# SSH Encryption Key (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SSH_ENCRYPTION_KEY=your_ssh_encryption_key_here
